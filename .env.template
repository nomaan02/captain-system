# Captain System — Production Environment Variables
# Copy to .env and fill in real values:
#   cp .env.template .env && nano .env
#
# For Isaac's VPS, copy to .env.isaac and change credentials.
# ------------------------------------------------------------------

# ── TOPSTEP AUTHENTICATION (REQUIRED) ────────────────────────────
TOPSTEP_USERNAME=your_topstep_email@example.com
TOPSTEP_API_KEY=your_topstep_api_key_here

# Trading account (from TopstepX dashboard)
TOPSTEP_ACCOUNT_NAME=PRAC-V2-XXXXXX-XXXXXXXX
TRADING_ENVIRONMENT=PAPER

# Auto-execute signals (bypass TAKEN/SKIPPED confirmation)
# Set to true ONLY for practice accounts or when you want fully automated trading.
# When false (default), signals appear in GUI and require manual confirmation.
AUTO_EXECUTE=false

# ── MULTI-INSTANCE TRADE ALTERNATION (optional) ────────────────
# When running two independent Captain instances for different accounts,
# set INSTANCE_PARITY to split trades between them:
#   0 = take signals 1, 3, 5, ... (odd counter)
#   1 = take signals 2, 4, 6, ... (even counter)
# Leave empty or unset to disable (take all signals — normal single-instance mode).
INSTANCE_PARITY=

# ── VAULT ENCRYPTION (REQUIRED) ─────────────────────────────────
# AES-256-GCM master key for API credential vault.
# Generate once: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# CRITICAL: Save this key somewhere safe — losing it means re-encrypting all vault data.
VAULT_MASTER_KEY=

# ── TELEGRAM NOTIFICATIONS (optional but recommended) ────────────
# Create a bot via @BotFather on Telegram, paste token here.
# Get chat ID: send a message to the bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── QUESTDB (override defaults only if customized) ───────────────
# QUESTDB_USER=admin
# QUESTDB_PASSWORD=quest

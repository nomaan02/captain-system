{
  "version": "1.0",
  "created": "2026-03-14",
  "description": "Regression test scenarios per Program3_Architecture.md Section 14.1",
  "tolerance": 0.01,
  "minimum_scenarios": 20,
  "total_scenarios": 24,
  "scenarios": [
    {"id": "REG-01", "group": "regime", "test": "test_b2_regime::TestBinaryRegimeHighVol", "description": "Binary regime: sigma > phi -> HIGH_VOL"},
    {"id": "REG-02", "group": "regime", "test": "test_b2_regime::TestBinaryRegimeLowVol", "description": "Binary regime: sigma < phi -> LOW_VOL"},
    {"id": "REG-03", "group": "regime", "test": "test_b2_regime::TestRegimeNeutralFallback", "description": "REGIME_NEUTRAL fallback -> equal probs"},
    {"id": "AIM-04", "group": "aim", "test": "test_b3_aim::TestAllAimsActive", "description": "All Tier-1 AIMs active -> combined_modifier in [0.5, 1.5]"},
    {"id": "AIM-05", "group": "aim", "test": "test_b3_aim::TestAllAimsSuppressed", "description": "All AIMs suppressed -> combined_modifier = 1.0"},
    {"id": "AIM-06", "group": "aim", "test": "test_b3_aim::TestMixedActiveAims", "description": "Mixed active/suppressed AIMs"},
    {"id": "KEL-07", "group": "kelly", "test": "test_b4_kelly::TestNormalKellySizing", "description": "Normal blended Kelly, contracts >= 1"},
    {"id": "KEL-08", "group": "kelly", "test": "test_b4_kelly::TestSiloDrawdownBlocked", "description": "Silo drawdown > 30% -> all BLOCKED"},
    {"id": "KEL-09", "group": "kelly", "test": "test_b4_kelly::TestMddConstraintBinding", "description": "MDD constraint binding -> 0 contracts"},
    {"id": "KEL-10", "group": "kelly", "test": "test_b4_kelly::TestLevel2Override", "description": "Level 2 sizing override halves contracts"},
    {"id": "KEL-11", "group": "kelly", "test": "test_b4_kelly::TestPassEvalRiskGoal", "description": "PASS_EVAL risk goal reduces Kelly"},
    {"id": "KEL-12", "group": "kelly", "test": "test_b4_kelly::TestZeroKelly", "description": "No edge -> kelly=0, contracts=0"},
    {"id": "SEL-13", "group": "selection", "test": "test_b5_selection::TestUncorrelatedAssets", "description": "Two uncorrelated assets -> both selected"},
    {"id": "SEL-14", "group": "selection", "test": "test_b5_selection::TestCorrelatedAssets", "description": "Two correlated assets -> lower-scoring reduced"},
    {"id": "QUA-15", "group": "quality", "test": "test_b5b_quality::TestQualityAboveCeiling", "description": "Quality above ceiling -> passes, multiplier=1.0"},
    {"id": "QUA-16", "group": "quality", "test": "test_b5b_quality::TestQualityBetweenFloorAndCeiling", "description": "Quality between floor/ceiling -> graduated multiplier"},
    {"id": "QUA-17", "group": "quality", "test": "test_b5b_quality::TestQualityBelowFloor", "description": "Quality below floor -> filtered out"},
    {"id": "CBR-18", "group": "circuit_breaker", "test": "test_b5c_circuit::TestAllLayersPass", "description": "All CB layers pass -> no blocks"},
    {"id": "CBR-19", "group": "circuit_breaker", "test": "test_b5c_circuit::TestL1DailyLossBreach", "description": "L1 daily loss beta breach -> BLOCKED"},
    {"id": "CBR-20", "group": "circuit_breaker", "test": "test_b5c_circuit::TestL2ConsecutiveLosses", "description": "L2 consecutive losses >= 5 -> BLOCKED"},
    {"id": "SIG-21", "group": "signal", "test": "test_b6_signal::TestSignalStructure", "description": "Signal has all required fields"},
    {"id": "OFF-22", "group": "offline", "test": "test_offline_feedback::TestEwmaUpdateAfterWin", "description": "EWMA update after winning trade"},
    {"id": "OFF-23", "group": "offline", "test": "test_offline_feedback::TestKellyRecomputeAfterUpdate", "description": "Kelly recompute after EWMA update"},
    {"id": "E2E-24", "group": "pipeline", "test": "test_pipeline_e2e::TestFullPipelineE2E", "description": "Full B2->B3->B4->B5->B5B->B5C->B6 pipeline"}
  ]
}

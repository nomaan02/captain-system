# Runtime data
questdb/db/
redis/
backups/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Secrets
vault/keys.vault
vault-backup/
nginx/certs/server.key
nginx/certs/server.crt

# Python
__pycache__/
*.pyc
.env

# Claude Code local config
.claude/

# Windows/WSL metadata
*:Zone.Identifier

# Node
node_modules/

# Old GUI backup
captain-gui-old/

# Test artifacts
test-results/

# Images (tracked in docs/Images/ but too large for git)
docs/Images/

# GUI screenshots (build artifacts)
captain-gui/*.png
captain-gui/*.jpg

# Logs (track structure, not content)
logs/incidents/*
logs/crash_reports/*
!logs/incidents/.gitkeep
!logs/crash_reports/.gitkeep

# Data (external market data, not tracked)
data/market/
data/vix/
data/macro/
data/options/
data/cot/
data/calendar/
data/roll_calendar/
# P1/P2 outputs ARE tracked — required for Kelly/EWMA bootstrap on all instances
# data/p1_outputs/
# data/p2_outputs/

# TSM validated copies (auto-generated)
config/tsm/validated/

# Config copies synced into Docker build contexts by captain-start.sh
captain-offline/_config/
captain-online/_config/
captain-command/_config/

# Playwright
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Audit worktrees (temporary git worktrees from audit runner)
.audit-worktrees/

# External tool data
.voicetree/
voicetree-*/
.nogic/
.mcp.json

# Runtime logs
logs/*.log

# GUI build prompts / agent scaffolding (not production code)
captain-gui/agent-skills/
captain-gui/docs/
captain-gui/PSEUDOTRADER_DASHBOARD_PROMPT.md
